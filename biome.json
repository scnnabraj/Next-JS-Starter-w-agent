{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "domains": {
      "next": "recommended",
      "react": "recommended"
    },
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessFragments": {
          "fix": "safe",
          "level": "on"
        },
        "noUselessCatch": "error",
        "noUselessTypeConstraint": "error",
        "useOptionalChain": {
          "fix": "safe",
          "level": "error"
        }
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noDoubleEquals": "error",
        "noConsole": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "allow": ["assert", "error", "info", "warn"]
          }
        },
        "noDuplicateCase": "error",
        "noIrregularWhitespace": "error",
        "noVar": "error",
        "noDuplicateJsxProps": "error",
        "noArrayIndexKey": "warn",
        "noExplicitAny": {
          "level": "info",
          "options": {}
        },
        "noEmptyBlock": "error",
        "noDuplicateProperties": "warn"
      },
      "correctness": {
        "noUnusedVariables": {
          "fix": "safe",
          "level": "error"
        },
        "noConstAssign": "error",
        "noUndeclaredDependencies": "error",
        "useHookAtTopLevel": "error",
        "noUnusedImports": {
          "fix": "safe",
          "level": "error"
        },
        "noUnknownUnit": "error",
        "useExhaustiveDependencies": {
          "fix": "safe",
          "level": "warn"
        }
      },
      "style": {
        "useConst": "error",
        "useFragmentSyntax": "error",
        "useDefaultParameterLast": "error",
        "useImportType": "off",
        "useConsistentArrayType": {
          "level": "error",
          "fix": "safe",
          "options": {
            "syntax": "generic"
          }
        }
      },
      "a11y": {
        "useAltText": "error",
        "useSemanticElements": "warn",
        "useKeyWithClickEvents": "warn",
        "noStaticElementInteractions": "info"
      },
      "performance": {
        "noImgElement": "error"
      },
      "security": {
        "noBlankTarget": "error"
      }
    }
  }
}
